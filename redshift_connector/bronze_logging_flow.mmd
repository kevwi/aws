flowchart TD

  %% =========================
  %% BRONZE PIPELINE STEP
  %% =========================
  A[Bronze step runs<br/>e.g. ingest.py] --> B[Python call<br/>log_event(...)]

  %% =========================
  %% PYTHON LAYER
  %% =========================
  B --> C[CALL control.sp_log_pipeline_event_smart<br/>(domain, app, status, metal, location, jobid)]

  %% =========================
  %% STORED PROC BEHAVIOR
  %% =========================
  C --> D{Is metal = bronze?}
  D -- Yes --> E[Allocate new jobid<br/>via config_key1_sequence]
  D -- No --> F[Require existing jobid]

  E --> G[Resolve / allocate codes<br/>process_name, status, metal]
  F --> G

  %% =========================
  %% WRITE LOG ROW
  %% =========================
  G --> H[Insert row into<br/>control.pipeline_log]

  %% =========================
  %% ENGINEER EXPERIENCE
  %% =========================
  H --> I[SELECT * FROM control.pipeline_log<br/>ORDER BY created DESC]
